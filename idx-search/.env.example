# MLS GRID API
MLSGRID_ACCESS_TOKEN=your_mlsgrid_access_token_here
MLSGRID_ORIGINATING_SYSTEM=actris

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# JWT Secret (use a long random string)
JWT_SECRET=your_very_long_random_secret_here_change_this

# Admin credentials (your realtor account)
ADMIN_EMAIL=you@austintxhomes.co

# Email (for saved search alerts) — works with Gmail, SendGrid, any SMTP
# For Gmail: set EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, use an App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM_NAME=Luke Allen
EMAIL_FROM=you@austintxhomes.co

# Public URL of your site (used in alert email links)
SITE_URL=https://austintxhomes.co

# Server
PORT=3000
