run = "bash start.sh"
modules = ["nodejs-20"]

[[ports]]
localPort = 3002
externalPort = 80

[[ports]]
localPort = 9876
externalPort = 3000

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/start.sh"
waitForPort = 3002

[deployment]
deploymentTarget = "gce"
run = ["sh", "-c", "bash start.sh"]
